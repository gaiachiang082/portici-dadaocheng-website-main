# =============================================================================
# Portici DaDaocheng — environment contract
# Copy to .env and fill in values. Never commit real secrets.
# Vite reads from this directory (see vite.config envDir); the Node server uses the same file in dev.
# =============================================================================

# --- Runtime (Railway / hosting) ---
# Set automatically by npm/pnpm scripts in many setups; production start uses NODE_ENV=production.
# NODE_ENV=development

# HTTP port (Express). Railway injects PORT.
# PORT=3000

# --- Validated in server/_core/env.ts ---
# OAuth / WebDev client id (server sdk + client login URL). Required when NODE_ENV=production (min presence).
# VITE_APP_ID=

# Session cookie signing secret. Required when NODE_ENV=production (min 16 characters). Optional in dev — a fallback key is used with a console warning if unset.
# JWT_SECRET=

# OAuth provider base URL; leave empty to disable OAuth login (server logs a warning).
# OAUTH_SERVER_URL=

# If set, this openId is granted admin on user upsert (see server/db.ts).
# OWNER_OPEN_ID=

# Forge / built-in API proxy (maps, storage, LLM, notifications, etc.). Optional; features check before use.
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# --- Database (validated in server/_core/env.ts; read in server/db.ts, drizzle.config.ts) ---
# MySQL / TiDB connection URL (TLS expected for hosted DBs).
MYSQL_DATABASE=mysql://root:DvmPskoBdISEjfTDWeXCZwzDiHultmJH@junction.proxy.rlwy.net:21383/railway

# --- Stripe (server/stripe/*; not part of ENV object) ---
# STRIPE_SECRET_KEY=
# Webhook signature verification; omit only for local experimentation (see server/stripe/webhook.ts).
# STRIPE_WEBHOOK_SECRET=

# --- Email (server/email/resend.ts) ---
# RESEND_API_KEY=

# --- Client-only (VITE_* exposed to the browser — use public values only) ---
# OAuth portal URL for login redirect (client/src/const.ts).
# VITE_OAUTH_PORTAL_URL=

# Optional: Umami analytics (client/src/main.tsx).
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# Optional: Forge proxy from the browser (client/src/components/Map.tsx).
# VITE_FRONTEND_FORGE_API_URL=
# VITE_FRONTEND_FORGE_API_KEY=

# --- Sanity (browser client: client/src/SanityClient.ts) ---
# Must match the project + dataset used in Sanity Studio (sanity.cli.js / manage.sanity.io).
# If unset, defaults to project kchhwq30 and dataset production.
# VITE_SANITY_PROJECT_ID=kchhwq30
# VITE_SANITY_DATASET=production
